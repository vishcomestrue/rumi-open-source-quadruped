<mujoco model="motor_assembly">
  <compiler angle="radian" meshdir="assets/meshes"/>

  <option iterations="1" ls_iterations="5" timestep="0.004" integrator="Euler">
    <flag eulerdamp="disable"/>
  </option>

  <default>
    <joint axis="0 0 1" armature="0.0005" damping="0.05"/>
  </default>

  <visual>
    <global offwidth="1280" offheight="720"/>
    <quality shadowsize="4096"/>
    <map znear="0.01"/>
  </visual>

  <asset>
    <mesh name="motor"    file="motor.stl"          scale="0.001 0.001 0.001"/>
    <mesh name="disk"     file="disk_with_hole.stl"  scale="0.001 0.001 0.001"/>
    <mesh name="cylinder" file="cylinder_pin.stl"    scale="0.001 0.001 0.001"/>

    <material name="motor_mat"    rgba="0.3 0.3 0.3 1"/>
    <material name="disk_mat"     rgba="0.7 0.2 0.2 1"/>
    <material name="cylinder_mat" rgba="0.2 0.7 0.2 1"/>
  </asset>

  <worldbody>
    <geom name="floor" type="plane" size="1 1 0.1" rgba="1 1 1 1.0"/>

    <camera name="fixed_cam" pos="-0.009 -0.206 0.066"
            xyaxes="0.999 -0.044 0.000 0.013 0.305 0.952"/>

    <body name="motor_body" pos="0 0 0.048" quat="0.7071068 0.7071068 0 0">
      <geom name="motor_geom" type="mesh" mesh="motor" material="motor_mat"
            contype="0" conaffinity="0"/>
      <inertial pos="0 0 0" mass="0.130" diaginertia="0.001 0.001 0.001"/>

      <body name="disk_body" pos="0 0 0.024" axisangle="0 0 1 -3.14159">
        <joint name="disk_joint" type="hinge" pos="0 0 0"
               limited="false" range="0 6.28" frictionloss="0.01"/>
        <geom name="disk_geom" type="mesh" mesh="disk" material="disk_mat"
              contype="0" conaffinity="0"/>
        <inertial pos="0 0 0" mass="0.004"
                  diaginertia="1.96e-05 1.96e-05 3.92e-05"/>

        <body name="cylinder_body" pos="0 0.01 0">
          <geom name="cylinder_geom" type="mesh" mesh="cylinder"
                material="cylinder_mat" contype="0" conaffinity="0"/>
          <inertial pos="0 0 0.0005" mass="0.0005"
                    diaginertia="0.00000001 0.00000001 0.00000001"/>
        </body>
      </body>
    </body>

    <light directional="true" pos="0 0 1"      dir="0 0 -1"    diffuse="0.6 0.6 0.6"/>
    <light directional="true" pos="0 -0.5 0.5" dir="0 1 -0.5"  diffuse="0.5 0.5 0.5"/>
    <light directional="true" pos="0.5 0 0.5"  dir="-1 0 -0.5" diffuse="0.3 0.3 0.3"/>
    <light directional="true" pos="-0.5 0 0.5" dir="1 0 -0.5"  diffuse="0.3 0.3 0.3"/>
    <light directional="true" pos="0 0.5 0.5"  dir="0 -1 -0.5" diffuse="0.2 0.2 0.2"/>
  </worldbody>

  <actuator>
    <!-- Position actuator: kp=10 Nm/rad, kd=0. Gains will be tuned during sysid. -->
    <position name="disk_motor" joint="disk_joint" kp="10" kv="0"
              forcerange="-6.0 6.0"/>
  </actuator>

  <sensor>
    <jointpos name="disk_angle"    joint="disk_joint"/>
    <jointvel name="disk_velocity" joint="disk_joint"/>
  </sensor>

  <keyframe>
    <key name="home" qpos="0" ctrl="0"/>
  </keyframe>

</mujoco>
